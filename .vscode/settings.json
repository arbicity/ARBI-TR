{
    "workbench.colorCustomizations": {
        "commandCenter.border": "#e7e7e799",
        "editorGroup.border": "#db3354",
        "sash.hoverBorder": "#db3354",
        "titleBar.activeBackground": "#ba213f",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#ba213f99",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "keyword.operator.arithmetic.python",
                "settings": {
                    "foreground": "#00d9ff"
                }
            },
            {
                "scope": "keyword.operator.comparison.python",
                "settings": {
                    "foreground": "#0077ff"
                }
            },
            {
                "scope": "variable.parameter.function-call.python",
                // "scope": "meta.function-call.arguments.python",
                // "scope": "meta.function-call.python",
                // "scope": "source.python",
                "settings": {
                    "foreground": "#7a99f5"
                }
            },
        ]
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "peacock.remoteColor": "#ba213f"
}